# PocketBase URL (sin slash al final)
# Interna — usada por Astro SSR para llamar a PocketBase
POCKETBASE_URL=http://localhost:8090

# Pública — usada para construir URLs de archivos que el browser pueda alcanzar
# En dev es la misma, en prod es https://pb.evesan.rocks
POCKETBASE_PUBLIC_URL=http://localhost:8090
