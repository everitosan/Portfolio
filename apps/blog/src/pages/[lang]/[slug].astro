---
import BlogLayout from '@/layouts/BlogLayout.astro'
import TagBadge from '@/components/TagBadge.astro'
import Card from 'ui/lib/Card.svelte'
import { getRepository, readingTime } from '@/lib/repository'
import type { Lang, Tag } from '@/lib/types'
import { marked } from 'marked'

const { lang, slug } = Astro.params
if (lang !== 'en' && lang !== 'es') return Astro.redirect('/en', 301)

const validLang = lang as Lang

let post
try {
  post = await getRepository().getPost(slug!)
} catch {
  return new Response(null, { status: 404 })
}

const tags = (post.expand?.tags ?? []) as Tag[]
const html = marked.parse(post.content)
const mins = readingTime(post.content)

const date = new Date(post.published_at).toLocaleDateString(
  validLang === 'es' ? 'es-MX' : 'en-US',
  { year: 'numeric', month: 'long', day: 'numeric' }
)

const readLabel = validLang === 'es' ? `${mins} min de lectura` : `${mins} min read`
---

<BlogLayout
  title={`${post.title} — Everardo's Blog`}
  description={post.excerpt}
  ogImage={post.cover_url || undefined}
  lang={validLang}
  canonicalSlug={post.slug}
>
  <Card variant="primary">
    <article class="post">
      {post.cover_url && (
        <img class="cover" src={post.cover_url} alt={post.title} />
      )}

      <header class="post-header">
        <div class="post-meta">
          <time datetime={post.published_at}>{date}</time>
          <span class="sep">·</span>
          <span>{readLabel}</span>
        </div>
        <h1 class="post-title">{post.title}</h1>
        <p class="post-excerpt">{post.excerpt}</p>
        {tags.length > 0 && (
          <div class="post-tags">
            {tags.map((tag) => <TagBadge name={tag.name} slug={tag.slug} lang={validLang} />)}
          </div>
        )}
      </header>

      <div class="post-content" set:html={html} />

      <footer class="post-footer">
        <a href={`/${validLang}`}>
          ← {validLang === 'es' ? 'Volver al blog' : 'Back to blog'}
        </a>
      </footer>
    </article>
  </Card>
</BlogLayout>

<style lang="scss">
  @use 'ui/Styles/colors';
  @use 'ui/Styles/typography';
  @use 'ui/Styles/utils';

  :global(.Card),
  :global(.Card__main),
  :global(.Card__main__content),
  :global(.Card__main__content__wrapper) {
    min-width: 0;
  }
  :global(.Card__main__content__wrapper) {
    max-height: none !important;
    overflow-y: visible !important;
  }

  .post {
    padding: utils.sizing(1);
    min-width: 0;
    overflow-wrap: anywhere;
    word-break: break-word;
  }

  .post-content { min-width: 0; max-width: 100%; }

  .cover {
    width: 100%;
    max-height: 420px;
    object-fit: cover;
    border-radius: 4px;
    margin-bottom: utils.sizing(3);
    display: block;
  }

  .post-header { margin-bottom: utils.sizing(3); }

  .post-meta {
    @include typography.techie-small-text;
    color: var(--color-muted);
    margin-bottom: utils.sizing(1);
    display: flex;
    gap: utils.sizing(0.5);
    align-items: center;
  }
  .sep { opacity: 0.4; }

  .post-title {
    @include typography.title-text;
    font-size: clamp(1.4rem, 3vw, 2rem);
    color: colors.$yellow;
    line-height: 1.25;
    margin-bottom: utils.sizing(1);
  }

  .post-excerpt {
    @include typography.regular-text;
    color: colors.$white;
    opacity: 0.65;
    margin-bottom: utils.sizing(1.5);
  }

  .post-tags { display: flex; flex-wrap: wrap; gap: utils.sizing(0.5); }

  /* Prose */
  .post-content :global(h2),
  .post-content :global(h3),
  .post-content :global(h4) {
    font-family: 'Orbitron', sans-serif;
    color: colors.$yellow;
    margin: utils.sizing(3) 0 utils.sizing(1);
    line-height: 1.3;
  }
  .post-content :global(h2) { font-size: 1.3rem; }
  .post-content :global(h3) { font-size: 1.1rem; }
  .post-content :global(p) { margin-bottom: utils.sizing(1.5); }
  .post-content :global(ul),
  .post-content :global(ol) { padding-left: utils.sizing(2); margin-bottom: utils.sizing(1.5); }
  .post-content :global(li) { margin-bottom: utils.sizing(0.5); }
  .post-content :global(blockquote) {
    border-left: 3px solid colors.$yellow;
    padding-left: utils.sizing(1.5);
    color: colors.$white;
    opacity: 0.65;
    margin: utils.sizing(2) 0;
    font-style: italic;
  }
  .post-content :global(code) {
    font-family: 'Share Tech Mono', monospace;
    font-size: 0.875em;
    background: rgba(0,0,0,0.4);
    padding: 0.15em 0.4em;
    border-radius: 3px;
    border: 1px solid colors.$gray;
  }
  .post-content :global(pre) {
    background: rgba(0,0,0,0.5);
    border: 1px solid colors.$gray;
    border-radius: 4px;
    padding: utils.sizing(1.5);
    overflow-x: auto;
    max-width: 100%;
    width: 100%;
    box-sizing: border-box;
    margin-bottom: utils.sizing(2);
  }
  .post-content :global(pre code) {
    background: none;
    border: none;
    padding: 0;
    white-space: pre;
    word-break: normal;
    overflow-wrap: normal;
  }
  .post-content :global(a) { color: colors.$yellow; overflow-wrap: anywhere; }
  .post-content :global(img) { margin: utils.sizing(2) 0; }
  .post-content :global(hr) {
    border: none;
    border-top: 1px solid colors.$gray;
    margin: utils.sizing(3) 0;
  }

  .post-footer {
    margin-top: utils.sizing(3);
    padding-top: utils.sizing(2);
    border-top: 1px solid colors.$gray;
    font-family: 'Share Tech Mono', monospace;
    font-size: 13px;
  }
  .post-footer a { color: var(--color-muted); }
  .post-footer a:hover { color: colors.$yellow; }
</style>
